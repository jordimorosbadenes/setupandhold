---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/withBase';
import { GUMROAD_PREMIUM_URL, GUMROAD_PRODUCT_ID, PUZZLEGEN_URL } from '../config/site';

const apiBase = PUZZLEGEN_URL;          // Render backend (fallback)
const localPuzzle = withBase('/puzzle/index.html'); // static JS version
---

<BaseLayout
  title="Puzzle Generator"
  description="Genera puzzles 3D, visualiza soluciones y descarga STL listo para imprimir."
>
  <section class="hero">
    <div class="hero-copy prose">
      <h1>PuzzleStudio3D</h1>
      <p>
        Genera y personaliza puzzles 3D: elige el tipo de puzzle, personaliza en el editor de texturas, y exporta de manera flexible a STL/3MF listo para impresión.
      </p>
      <div class="hero-actions">
        <a class="button" href={withBase('/')}>Ir al inicio</a>
      </div>
    </div>
  </section>

  <section class="construction-warning">
    <div class="construction-content">
      <h2>🚧 Página en Construcción</h2>
      <p>Esta página aún no está terminada y algunas funcionalidades pueden no funcionar correctamente o estar incompletas.</p>
    </div>
  </section>

  <!-- Premium section — standalone card above the puzzle -->
  <section class="premium-section" id="premium-bar"
    data-gumroad-product-id={GUMROAD_PRODUCT_ID}
    data-gumroad-url={GUMROAD_PREMIUM_URL}
  >
    <div class="premium-section__row">
      <span class="premium-section__label">🔒 El canvas del puzzle está bloqueado.</span>
      <button type="button" class="premium-section__toggle" id="premium-toggle">Desbloquear</button>
    </div>
    <div class="premium-gate" id="premium-gate" style="display:none;">
      <p class="premium-gate__text">Introduce tu clave de compra para desbloquear la vista del puzzle.</p>
      <div class="premium-gate__cta">
        <a class="premium-gate__link" href={GUMROAD_PREMIUM_URL} target="_blank" rel="noreferrer">Conseguir clave</a>
      </div>
      <div class="premium-gate__row">
        <input
          class="premium-gate__input"
          type="text"
          inputmode="text"
          autocomplete="one-time-code"
          placeholder="Clave de compra"
          aria-label="Clave"
          id="premium-key"
        />
        <button type="button" class="premium-gate__btn" id="premium-unlock">🔓 Verificar</button>
      </div>
      <div class="premium-gate__error" id="premium-error" aria-live="polite"></div>
    </div>
  </section>

  <!-- Puzzle embed — seamless, no visible container -->
  <section
    class="puzzle-embed"
    data-api-base={apiBase}
    data-local-puzzle={localPuzzle}
    data-gumroad-product-id={GUMROAD_PRODUCT_ID}
    data-gumroad-url={GUMROAD_PREMIUM_URL}
  >
    <!-- Wait overlay while backend cold-starts -->
    <div id="embed-wait" class="embed-wait" aria-live="polite">
      <div class="embed-loader" aria-hidden="true">🧩</div>
      <div class="embed-msg">
        <strong>Arrancando backend…</strong>
        <span class="embed-note">Render se está despertando. Puede tardar ~1 minuto la primera vez.</span>
        <span class="embed-status" aria-live="polite"></span>
      </div>
    </div>

    <!-- The entire PuzzleGenerator UI lives inside this iframe.
         No HTML duplication, no CSS overrides — the backend serves
         its own page with ?embed=1 to activate the embed theme.
         Transparent background with iframes: https://fvsch.com/transparent-iframes -->
    <iframe
      id="puzzle-iframe"
      class="puzzle-iframe"
      title="Puzzle Generator"
      scrolling="no"
      allowtransparency="true"
      style="background: transparent;"
      allowfullscreen
    ></iframe>
  </section>

  <script define:vars={{ apiBase, localPuzzle, GUMROAD_PRODUCT_ID }}>
    (() => {
      const embed  = document.querySelector('.puzzle-embed');
      const iframe = document.getElementById('puzzle-iframe');
      const waitEl = document.getElementById('embed-wait');
      const statusEl = embed?.querySelector('.embed-status');
      const theme  = document.documentElement.dataset.theme || 'dark';

      /* ---- Mode selection: ?backend=render uses Render; default = local ---- */
      const params  = new URLSearchParams(window.location.search);
      const useRender = params.get('backend') === 'render' && apiBase;
      const renderBase = (apiBase || '').replace(/\/$/, '');

      /* ---- Health polling (Render mode only) ---- */
      const pingHealth = async () => {
        try {
          const ctrl = new AbortController();
          const t = setTimeout(() => ctrl.abort(), 8000);
          const res = await fetch(`${renderBase}/health`, { signal: ctrl.signal });
          clearTimeout(t);
          return res.ok;
        } catch { return false; }
      };

      const boot = async () => {
        if (useRender) {
          /* Render mode — poll health, then load remote iframe */
          let ok = false;
          while (!ok) {
            ok = await pingHealth();
            if (!ok) {
              if (statusEl) statusEl.textContent = 'Esperando al backend…';
              await new Promise(r => setTimeout(r, 3000));
            }
          }
          if (statusEl) statusEl.textContent = 'Cargando interfaz…';
          iframe.src = `${renderBase}/?embed=1&theme=${theme}`;
        } else {
          /* Local mode — load static puzzle directly, no health check */
          waitEl?.classList.add('hide');
          iframe.src = `${localPuzzle}?embed=1&theme=${theme}`;
        }
      };

      /* ---- Messages from iframe ---- */
      let iframeLoaded = false;

      window.addEventListener('message', (e) => {
        const d = e.data;
        if (!d || typeof d !== 'object') return;

        if (d.type === 'puzzle-loaded') {
          iframeLoaded = true;
          waitEl?.classList.add('hide');
          iframe.classList.add('loaded');
        }

        if (d.type === 'puzzle-resize' && typeof d.height === 'number') {
          iframe.style.height = d.height + 'px';
        }
      });

      // Fallback: use iframe load event if postMessage doesn't fire
      iframe.addEventListener('load', () => {
        if (!iframeLoaded) {
          setTimeout(() => {
            iframeLoaded = true;
            waitEl?.classList.add('hide');
            iframe.classList.add('loaded');
          }, 500);
        }
      });

      /* ---- Theme bridge ---- */
      const syncTheme = () => {
        const theme = document.documentElement.dataset.theme || 'dark';
        try { iframe.contentWindow?.postMessage({ type: 'theme-change', theme }, '*'); } catch {}
      };

      new MutationObserver(() => syncTheme())
        .observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

      /* ---- Premium lock ---- */
      const premiumSection = document.getElementById('premium-bar');
      const premiumToggle  = document.getElementById('premium-toggle');
      const premiumGate    = document.getElementById('premium-gate');
      const premiumKey     = document.getElementById('premium-key');
      const premiumBtn     = document.getElementById('premium-unlock');
      const premiumError   = document.getElementById('premium-error');

      const setPremium = (unlocked) => {
        try { iframe.contentWindow?.postMessage({ type: 'premium-status', unlocked }, '*'); } catch {}
        if (unlocked && premiumSection) premiumSection.classList.add('unlocked');
      };

      premiumToggle?.addEventListener('click', () => {
        const hidden = premiumGate.style.display === 'none';
        premiumGate.style.display = hidden ? '' : 'none';
        if (hidden) setTimeout(() => premiumKey?.focus(), 0);
      });

      const verifyKey = async () => {
        const key = (premiumKey?.value || '').trim();
        if (!key) {
          showPremiumError('Introduce una clave válida.');
          return;
        }
        if (!GUMROAD_PRODUCT_ID) {
          showPremiumError('Falta configurar el product_id de Gumroad.');
          return;
        }
        const prev = premiumBtn.textContent;
        premiumBtn.disabled = true;
        premiumBtn.textContent = 'Verificando…';
        showPremiumError('');

        try {
          const body = new URLSearchParams({
            product_id: GUMROAD_PRODUCT_ID,
            license_key: key,
            increment_uses_count: 'false',
          });
          const res = await fetch('https://api.gumroad.com/v2/licenses/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body,
          });
          const data = await res.json().catch(() => null);

          if (!res.ok || !data || data.success !== true) {
            showPremiumError('Clave no válida. Revisa que la hayas copiado tal cual.');
            return;
          }
          const p = data.purchase || {};
          if (p.refunded || p.disputed || p.chargebacked) {
            showPremiumError('Esta compra no está activa (reembolso o disputa).');
            return;
          }
          setPremium(true);
        } catch {
          showPremiumError('No se pudo verificar la clave. Inténtalo de nuevo.');
        } finally {
          premiumBtn.disabled = false;
          premiumBtn.textContent = prev;
        }
      };

      function showPremiumError(text) {
        if (!premiumError) return;
        premiumError.textContent = text;
        premiumError.style.display = text ? 'block' : 'none';
      }

      premiumBtn?.addEventListener('click', verifyKey);
      premiumKey?.addEventListener('keydown', (e) => { if (e.key === 'Enter') verifyKey(); });

      /* ---- Start ---- */
      boot();
    })();
  </script>
</BaseLayout>

<style is:global>
  /* ============================================================
     Puzzle embed wrapper — only layout & host-side UI styles.
     NO backend CSS overrides here; those live in the backend's
     style.css under the "EMBED MODE" section.
     ============================================================ */

  .puzzle-embed {
    position: relative;
    margin: 0 auto;
    max-width: 1100px;
    background: transparent;
    padding: 0;
    min-height: 300px;
  }

  .puzzle-iframe {
    display: block;
    width: 100%;
    min-height: 300px;
    height: 800px;
    border: none;
    overflow: hidden;
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .puzzle-iframe.loaded {
    opacity: 1;
  }

  /* --- Wait overlay --- */
  .embed-wait {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    z-index: 20;
    transition: opacity 220ms ease, visibility 220ms ease;
  }
  .embed-wait.hide {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }
  .embed-loader {
    font-size: 32px;
    animation: embed-spin 1s linear infinite;
  }
  @keyframes embed-spin { to { transform: rotate(360deg); } }

  .embed-msg {
    display: grid;
    gap: 4px;
    color: var(--text);
    font-weight: 600;
  }
  .embed-msg .embed-note {
    color: var(--muted);
    font-weight: 500;
  }
  .embed-msg .embed-status {
    color: var(--muted);
    font-weight: 400;
    font-style: italic;
  }

  /* --- Premium section (standalone card) --- */
  .premium-section {
    margin: 20px auto;
    max-width: 1100px;
    padding: 16px 20px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--card);
    box-shadow: var(--shadow);
  }
  .premium-section.unlocked {
    display: none;
  }
  .premium-section__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .premium-section__label {
    color: var(--text);
    font-weight: 600;
  }
  .premium-section__toggle {
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg-soft);
    color: var(--text);
    font-weight: 600;
    cursor: pointer;
    transition: border-color 140ms ease, color 140ms ease;
  }
  .premium-section__toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .premium-gate {
    margin-top: 12px;
  }
  .premium-gate__text {
    color: var(--muted);
    font-size: 0.95rem;
    margin: 0 0 10px;
  }
  .premium-gate__cta {
    display: flex;
    justify-content: center;
    margin: 0 0 12px;
  }
  .premium-gate__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: #2a1a00 !important;
    background: linear-gradient(120deg, #f7e08a, #d4af37) !important;
    border: 1px solid rgba(212, 175, 55, 0.55);
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.18);
    transition: transform 140ms ease, box-shadow 140ms ease, filter 140ms ease;
  }
  .premium-gate__link:hover {
    transform: translateY(-1px);
    filter: brightness(1.02);
  }
  .premium-gate__row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 10px;
    align-items: center;
  }
  .premium-gate__input {
    width: 100%;
    padding: 10px 12px;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--text);
    font-weight: 600;
  }
  .premium-gate__btn {
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid rgba(52, 211, 153, 0.55);
    background: linear-gradient(120deg, #6ee7b7, #34d399);
    color: #062012;
    font-weight: 600;
    cursor: pointer;
    transition: transform 140ms ease;
    white-space: nowrap;
  }
  .premium-gate__btn:hover {
    transform: translateY(-1px);
  }
  .premium-gate__error {
    display: none;
    margin-top: 10px;
    color: #ff8a8a;
  }
  :root[data-theme='light'] .premium-gate__error {
    color: #cc3333;
  }

  /* --- Construction warning --- */
  .construction-warning {
    margin: 20px auto;
    max-width: 1100px;
    padding: 20px;
    background: rgba(255, 193, 7, 0.1);
    border: 1px solid rgba(255, 193, 7, 0.3);
    border-radius: var(--radius);
    text-align: center;
    color: var(--text);
  }
  .construction-warning h2 {
    margin: 0 0 10px;
    color: var(--text);
    font-size: 1.8rem;
  }
  .construction-warning p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .puzzle-embed { margin: 0 12px; }
    .premium-section { margin: 20px 12px; padding: 14px; }
  }
</style>
