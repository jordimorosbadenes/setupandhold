---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }: any) => !data.draft)).sort(
  (a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<BaseLayout title="Blog | setupandhold" description="Todas las entradas publicadas.">
  <div class="section-title">
    <h2>Blog</h2>
    <span class="pill">{posts.length} entradas</span>
  </div>
  <div class="post-grid">
    {posts.map((post: any) => <PostCard post={post} />)}
  </div>
</BaseLayout>
