---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../utils/withBase';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, tags } = post.data;
const formatted = new Date(date).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const giscusTerm = withBase(`/posts/${post.slug}`);
---
<article class="post-card">
  <a class="card-link" href={`/posts/${post.slug}`}>
    <div class="card-meta">
      <span class="pill">{formatted}</span>
      {tags?.length ? (
        <div class="tag-row">
          {tags.map((tag: string) => (
            <span class="tag" aria-label={`Etiqueta ${tag}`}>{tag}</span>
          ))}
        </div>
      ) : null}
    </div>
    <h3>{title}</h3>
    <p>{description}</p>
    <div class="card-reactions" data-giscus-term={giscusTerm} aria-hidden="true"></div>
  </a>
</article>

<script>
  const REPO        = 'jordimorosbadenes/setupandhold';
  const REPO_ID     = 'R_kgDOQxFETg';
  const CATEGORY    = 'Announcements';
  const CATEGORY_ID = 'DIC_kwDOQxFETs4C3D9B';

  function renderEl(el: HTMLElement, reactions: number, comments: number) {
    if (reactions === 0 && comments === 0) return;
    const parts: string[] = [];
    if (reactions > 0) parts.push(`❤️ ${reactions}`);
    if (comments > 0) parts.push(`💬 ${comments}`);
    el.textContent = parts.join('\u00a0\u00a0');
  }

  // 1. Render immediately from cache
  function loadFromStorage() {
    document.querySelectorAll<HTMLElement>('[data-giscus-term]').forEach((el) => {
      const term = el.dataset.giscusTerm;
      if (!term) return;
      try {
        const raw = localStorage.getItem(`giscus-meta:${term}`);
        if (!raw) return;
        const { reactions, comments } = JSON.parse(raw) as { reactions: number; comments: number };
        renderEl(el, reactions, comments);
      } catch {}
    });
  }

  // 2. Prefetch all terms in parallel — identify each iframe by event.source
  function prefetchMissing() {
    const items: Array<{ el: HTMLElement; term: string }> = [];
    document.querySelectorAll<HTMLElement>('[data-giscus-term]').forEach((el) => {
      const term = el.dataset.giscusTerm;
      if (term) items.push({ el, term });
    });
    if (items.length === 0) return;

    const theme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
    const wrap = document.createElement('div');
    wrap.style.cssText = 'position:absolute;width:1px;height:1px;overflow:hidden;top:-9999px;left:-9999px;';
    document.body.appendChild(wrap);

    // Map from iframe.contentWindow → {el, term}
    const sourceMap = new Map<MessageEventSource, { el: HTMLElement; term: string }>();
    let pending = items.length;

    function cleanup() {
      window.removeEventListener('message', onMessage);
      wrap.remove();
    }

    function onMessage(event: MessageEvent) {
      if (event.origin !== 'https://giscus.app') return;
      if (typeof event.data !== 'object' || !event.data.giscus) return;
      if (!event.source) return;
      const entry = sourceMap.get(event.source);
      if (!entry) return;
      const { discussion } = event.data.giscus;
      if (!discussion) return;

      // Remove so we only process the first metadata message per iframe
      sourceMap.delete(event.source);

      let reactions: number = discussion.reactionCount ?? 0;
      if (!reactions && discussion.reactions) {
        reactions = (Object.values(discussion.reactions) as number[]).reduce((a, b) => a + b, 0);
      }
      const comments: number = discussion.totalCommentCount ?? 0;
      localStorage.setItem(`giscus-meta:${entry.term}`, JSON.stringify({ reactions, comments }));
      renderEl(entry.el, reactions, comments);

      if (--pending <= 0) cleanup();
    }

    window.addEventListener('message', onMessage);

    // Create all iframes at once
    items.forEach(({ el, term }) => {
      const params = new URLSearchParams({
        origin: window.location.origin,
        repo: REPO, repoId: REPO_ID,
        category: CATEGORY, categoryId: CATEGORY_ID,
        mapping: 'pathname', term,
        strict: '0', reactionsEnabled: '1',
        emitMetadata: '1', inputPosition: 'top',
        theme, lang: 'es', session: '',
      });
      const iframe = document.createElement('iframe');
      iframe.src = `https://giscus.app/widget?${params}`;
      iframe.style.cssText = 'width:1px;height:1px;border:none;';
      wrap.appendChild(iframe);
      if (iframe.contentWindow) sourceMap.set(iframe.contentWindow, { el, term });
    });

    // Safety cleanup after 8s
    setTimeout(cleanup, 8000);
  }

  loadFromStorage();
  prefetchMissing();
</script>

<style>
  .card-reactions {
    font-size: 0.8rem;
    opacity: 0.7;
    margin-top: 0.75rem;
  }
  .card-reactions:empty {
    margin-top: 0;
  }
</style>
