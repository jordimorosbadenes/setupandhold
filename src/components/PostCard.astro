---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../utils/withBase';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, tags } = post.data;
const formatted = new Date(date).toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const giscusTerm = withBase(`/posts/${post.slug}`);
---
<article class="post-card">
  <a class="card-link" href={`/posts/${post.slug}`}>
    <div class="card-meta">
      <span class="pill">{formatted}</span>
      {tags?.length ? (
        <div class="tag-row">
          {tags.map((tag: string) => (
            <span class="tag" aria-label={`Etiqueta ${tag}`}>{tag}</span>
          ))}
        </div>
      ) : null}
    </div>
    <h3>{title}</h3>
    <p>{description}</p>
    <div class="card-reactions" data-giscus-term={giscusTerm} aria-hidden="true"></div>
  </a>
</article>

<script>
  // Token is injected at build time (PUBLIC_ prefix → safe for client bundles)
  const TOKEN: string = import.meta.env.PUBLIC_GISCUS_TOKEN ?? '';
  const CATEGORY_ID = 'DIC_kwDOQxFETs4C3D9B';

  // Shared cache so all cards on the same page share a single API call
  let discussionsCache: Array<{
    bodyText: string;
    reactionGroups: Array<{ content: string; reactors: { totalCount: number } }>;
    comments: { totalCount: number };
  }> | null = null;

  async function fetchAllDiscussions() {
    if (discussionsCache) return discussionsCache;
    if (!TOKEN) return [];
    const query = `{
      repository(owner:"jordimorosbadenes", name:"setupandhold") {
        discussions(first:100, categoryId:"${CATEGORY_ID}", orderBy:{field:CREATED_AT,direction:DESC}) {
          nodes {
            bodyText
            reactionGroups { content reactors { totalCount } }
            comments { totalCount }
          }
        }
      }
    }`;
    try {
      const res = await fetch('https://api.github.com/graphql', {
        method: 'POST',
        headers: {
          Authorization: `Bearer ${TOKEN}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ query }),
      });
      if (!res.ok) return [];
      const json = await res.json();
      discussionsCache = json?.data?.repository?.discussions?.nodes ?? [];
    } catch {
      discussionsCache = [];
    }
    return discussionsCache!;
  }

  async function loadReactions() {
    const els = document.querySelectorAll<HTMLElement>('[data-giscus-term]');
    if (!els.length) return;
    const discussions = await fetchAllDiscussions();

    els.forEach((el) => {
      const term = el.dataset.giscusTerm ?? '';
      // Giscus stores the full page URL in the discussion body; match by path segment
      const match = discussions.find((d) => d.bodyText.includes(term));
      if (!match) return;

      let reactions = 0;
      for (const g of match.reactionGroups) {
        reactions += g.reactors.totalCount;
      }
      const comments = match.comments.totalCount;
      if (reactions === 0 && comments === 0) return;

      const parts: string[] = [];
      if (reactions > 0) parts.push(`❤️ ${reactions}`);
      if (comments > 0) parts.push(`💬 ${comments}`);
      el.textContent = parts.join('\u00a0\u00a0');
    });
  }

  loadReactions();
</script>

<style>
  .card-reactions {
    font-size: 0.8rem;
    opacity: 0.7;
    margin-top: 0.75rem;
  }
  .card-reactions:empty {
    margin-top: 0;
  }
</style>
